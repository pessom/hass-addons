#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Init postfix - generate main.cf from template using HA config options
# ==============================================================================

set -e

bashio::log.level "$(bashio::config 'log_level')"
bashio::log.info "Generating Postfix configuration..."

# ── Helper: render a postfix parameter line or empty string ──────────────────
# Usage: cf_line "postfix_param" "value"
cf_line() { echo "${1} = ${2}"; }

# ── Data directory ───────────────────────────────────────────────────────────
if ! bashio::fs.directory_exists '/data/postfix'; then
    mkdir -p /data/postfix
    bashio::log.info "Created /data/postfix"
fi

# ── General ──────────────────────────────────────────────────────────────────
if bashio::config.has_value 'general.hostname'; then
    MYHOSTNAME=$(cf_line "myhostname" "$(bashio::config 'general.hostname')")
    echo "$(bashio::config 'general.hostname')" > /etc/mailname
else
    MYHOSTNAME=""
fi

if bashio::config.has_value 'general.domain'; then
    MYDOMAIN=$(cf_line "mydomain" "$(bashio::config 'general.domain')")
else
    MYDOMAIN=""
fi

if bashio::config.has_value 'general.origin'; then
    MYORIGIN=$(cf_line "myorigin" "$(bashio::config 'general.origin')")
else
    MYORIGIN=""
fi

if bashio::config.has_value 'general.mydestination'; then
    MYDESTINATION=$(cf_line "mydestination" "$(bashio::config 'general.mydestination')")
else
    MYDESTINATION="mydestination = localhost"
fi

# ── Network ──────────────────────────────────────────────────────────────────
INET_INTERFACES=$(bashio::config 'network.inet_interfaces')
INET_PROTOCOLS=$(bashio::config 'network.inet_protocols')

if bashio::config.has_value 'network.mynetworks'; then
    MYNETWORKS=$(cf_line "mynetworks" "$(bashio::config 'network.mynetworks | join(", ")')")
else
    MYNETWORKS=""
fi

if bashio::config.has_value 'network.relayhost'; then
    RELAYHOST=$(cf_line "relayhost" "$(bashio::config 'network.relayhost')")
else
    RELAYHOST=""
fi

if bashio::config.has_value 'network.relay_domains'; then
    RELAY_DOMAINS=$(cf_line "relay_domains" "$(bashio::config 'network.relay_domains | join(", ")')")
else
    RELAY_DOMAINS=""
fi

# ── TLS (outbound) ───────────────────────────────────────────────────────────
if bashio::config.has_value 'tls.smtp_level'; then
    SMTP_TLS_SECURITY_LEVEL=$(cf_line "smtp_tls_security_level" "$(bashio::config 'tls.smtp_level')")
else
    SMTP_TLS_SECURITY_LEVEL=""
fi

if bashio::config.has_value 'tls.smtp_cert_file'; then
    SMTP_TLS_CERT_FILE=$(cf_line "smtp_tls_cert_file" "$(bashio::config 'tls.smtp_cert_file')")
else
    SMTP_TLS_CERT_FILE=""
fi

if bashio::config.has_value 'tls.smtp_key_file'; then
    SMTP_TLS_KEY_FILE=$(cf_line "smtp_tls_key_file" "$(bashio::config 'tls.smtp_key_file')")
else
    SMTP_TLS_KEY_FILE=""
fi

# ── TLS (inbound) ────────────────────────────────────────────────────────────
if bashio::config.has_value 'tls.smtpd_level'; then
    SMTPD_TLS_SECURITY_LEVEL=$(cf_line "smtpd_tls_security_level" "$(bashio::config 'tls.smtpd_level')")
else
    SMTPD_TLS_SECURITY_LEVEL=""
fi

if bashio::config.has_value 'tls.smtpd_cert_file'; then
    SMTPD_TLS_CERT_FILE=$(cf_line "smtpd_tls_cert_file" "$(bashio::config 'tls.smtpd_cert_file')")
else
    SMTPD_TLS_CERT_FILE=""
fi

if bashio::config.has_value 'tls.smtpd_key_file'; then
    SMTPD_TLS_KEY_FILE=$(cf_line "smtpd_tls_key_file" "$(bashio::config 'tls.smtpd_key_file')")
else
    SMTPD_TLS_KEY_FILE=""
fi

# ── SASL (outbound) ──────────────────────────────────────────────────────────
if bashio::var.true "$(bashio::config 'sasl.smtp_enabled')"; then
    SMTP_SASL_AUTH_ENABLE="smtp_sasl_auth_enable = yes"

    if bashio::config.has_value 'sasl.smtp_username' && bashio::config.has_value 'sasl.smtp_password'; then
        SASL_USER=$(bashio::config 'sasl.smtp_username')
        SASL_PASS=$(bashio::config 'sasl.smtp_password')
        SASL_PASSWD_FILE="/share/postfix/sasl_passwd"
        mkdir -p /share/postfix
        if bashio::config.has_value 'network.relayhost'; then
            SASL_HOST=$(bashio::config 'network.relayhost')
        else
            SASL_HOST="*"
        fi
        echo "${SASL_HOST} ${SASL_USER}:${SASL_PASS}" > "${SASL_PASSWD_FILE}"
        chmod 600 "${SASL_PASSWD_FILE}"
        postmap "${SASL_PASSWD_FILE}"
        SMTP_SASL_PASSWORD_MAPS="smtp_sasl_password_maps = hash:${SASL_PASSWD_FILE}"
    else
        SMTP_SASL_PASSWORD_MAPS=""
    fi

    if bashio::config.has_value 'sasl.smtp_security_options'; then
        SMTP_SASL_SECURITY_OPTIONS=$(cf_line "smtp_sasl_security_options" "$(bashio::config 'sasl.smtp_security_options')")
    else
        SMTP_SASL_SECURITY_OPTIONS="smtp_sasl_security_options = noanonymous"
    fi
else
    SMTP_SASL_AUTH_ENABLE=""
    SMTP_SASL_PASSWORD_MAPS=""
    SMTP_SASL_SECURITY_OPTIONS=""
fi

# ── SASL (inbound) ───────────────────────────────────────────────────────────
if bashio::var.true "$(bashio::config 'sasl.smtpd_enabled')"; then
    SMTPD_SASL_AUTH_ENABLE="smtpd_sasl_auth_enable = yes"
    SMTPD_SASL_TYPE="smtpd_sasl_type = dovecot"
    SMTPD_SASL_PATH="smtpd_sasl_path = private/auth"
else
    SMTPD_SASL_AUTH_ENABLE=""
    SMTPD_SASL_TYPE=""
    SMTPD_SASL_PATH=""
fi

# ── Restrictions ─────────────────────────────────────────────────────────────
if bashio::config.has_value 'restrictions.relay_restrictions'; then
    SMTPD_RELAY_RESTRICTIONS=$(cf_line "smtpd_relay_restrictions" "$(bashio::config 'restrictions.relay_restrictions | join(", ")')")
else
    SMTPD_RELAY_RESTRICTIONS=""
fi

if bashio::config.has_value 'restrictions.recipient_restrictions'; then
    SMTPD_RECIPIENT_RESTRICTIONS=$(cf_line "smtpd_recipient_restrictions" "$(bashio::config 'restrictions.recipient_restrictions | join(", ")')")
else
    SMTPD_RECIPIENT_RESTRICTIONS=""
fi

if bashio::config.has_value 'restrictions.client_restrictions'; then
    SMTPD_CLIENT_RESTRICTIONS=$(cf_line "smtpd_client_restrictions" "$(bashio::config 'restrictions.client_restrictions | join(", ")')")
else
    SMTPD_CLIENT_RESTRICTIONS=""
fi

# ── Virtual domains ──────────────────────────────────────────────────────────
if bashio::config.has_value 'virtual.alias_domains'; then
    VIRTUAL_ALIAS_DOMAINS=$(cf_line "virtual_alias_domains" "$(bashio::config 'virtual.alias_domains | join(", ")')")
else
    VIRTUAL_ALIAS_DOMAINS=""
fi

if bashio::config.has_value 'virtual.alias_maps'; then
    VIRTUAL_ALIAS_MAPS=$(cf_line "virtual_alias_maps" "$(bashio::config 'virtual.alias_maps | join(", ")')")
else
    VIRTUAL_ALIAS_MAPS=""
fi

if bashio::config.has_value 'virtual.mailbox_domains'; then
    VIRTUAL_MAILBOX_DOMAINS=$(cf_line "virtual_mailbox_domains" "$(bashio::config 'virtual.mailbox_domains | join(", ")')")
else
    VIRTUAL_MAILBOX_DOMAINS=""
fi

if bashio::config.has_value 'virtual.mailbox_maps'; then
    VIRTUAL_MAILBOX_MAPS=$(cf_line "virtual_mailbox_maps" "$(bashio::config 'virtual.mailbox_maps | join(", ")')")
else
    VIRTUAL_MAILBOX_MAPS=""
fi

# ── Limits ───────────────────────────────────────────────────────────────────
if bashio::config.has_value 'limits.message_size_limit'; then
    MESSAGE_SIZE_LIMIT=$(cf_line "message_size_limit" "$(bashio::config 'limits.message_size_limit')")
else
    MESSAGE_SIZE_LIMIT=""
fi

if bashio::config.has_value 'limits.mailbox_size_limit'; then
    MAILBOX_SIZE_LIMIT=$(cf_line "mailbox_size_limit" "$(bashio::config 'limits.mailbox_size_limit')")
else
    MAILBOX_SIZE_LIMIT=""
fi

if bashio::config.has_value 'limits.process_limit'; then
    DEFAULT_PROCESS_LIMIT=$(cf_line "default_process_limit" "$(bashio::config 'limits.process_limit')")
else
    DEFAULT_PROCESS_LIMIT=""
fi

if bashio::config.has_value 'limits.connection_count_limit'; then
    SMTPD_CLIENT_CONNECTION_COUNT_LIMIT=$(cf_line "smtpd_client_connection_count_limit" "$(bashio::config 'limits.connection_count_limit')")
else
    SMTPD_CLIENT_CONNECTION_COUNT_LIMIT=""
fi

# ── Ports: submission (587) and smtps (465) ──────────────────────────────────
if bashio::var.true "$(bashio::config 'ports.submission_enabled')"; then
    SUBMISSION_SERVICE="submission inet  n       -       n       -       -       smtpd
        -o syslog_name=postfix/submission
        -o smtpd_tls_security_level=encrypt
        -o smtpd_sasl_auth_enable=yes
        -o smtpd_relay_restrictions=permit_sasl_authenticated,reject"
    bashio::log.info "Submission port 587 enabled"
else
    SUBMISSION_SERVICE=""
fi

if bashio::var.true "$(bashio::config 'ports.smtps_enabled')"; then
    SMTPS_SERVICE="smtps     inet  n       -       n       -       -       smtpd
        -o syslog_name=postfix/smtps
        -o smtpd_tls_wrappermode=yes
        -o smtpd_sasl_auth_enable=yes
        -o smtpd_relay_restrictions=permit_sasl_authenticated,reject"
    bashio::log.info "SMTPS port 465 enabled"
else
    SMTPS_SERVICE=""
fi

# ── Render template → master.cf ───────────────────────────────────────────────
sed \
    -e "s|{{SUBMISSION_SERVICE}}|${SUBMISSION_SERVICE}|g" \
    -e "s|{{SMTPS_SERVICE}}|${SMTPS_SERVICE}|g" \
    /etc/postfix/master.cf.tmpl > /etc/postfix/master.cf

sed -i '/^[[:space:]]*$/d' /etc/postfix/master.cf

# ── Render template → main.cf ─────────────────────────────────────────────────
sed \
    -e "s|{{MYHOSTNAME}}|${MYHOSTNAME}|g" \
    -e "s|{{MYDOMAIN}}|${MYDOMAIN}|g" \
    -e "s|{{MYORIGIN}}|${MYORIGIN}|g" \
    -e "s|{{MYDESTINATION}}|${MYDESTINATION}|g" \
    -e "s|{{INET_INTERFACES}}|${INET_INTERFACES}|g" \
    -e "s|{{INET_PROTOCOLS}}|${INET_PROTOCOLS}|g" \
    -e "s|{{MYNETWORKS}}|${MYNETWORKS}|g" \
    -e "s|{{RELAYHOST}}|${RELAYHOST}|g" \
    -e "s|{{RELAY_DOMAINS}}|${RELAY_DOMAINS}|g" \
    -e "s|{{SMTP_TLS_SECURITY_LEVEL}}|${SMTP_TLS_SECURITY_LEVEL}|g" \
    -e "s|{{SMTP_TLS_CERT_FILE}}|${SMTP_TLS_CERT_FILE}|g" \
    -e "s|{{SMTP_TLS_KEY_FILE}}|${SMTP_TLS_KEY_FILE}|g" \
    -e "s|{{SMTPD_TLS_SECURITY_LEVEL}}|${SMTPD_TLS_SECURITY_LEVEL}|g" \
    -e "s|{{SMTPD_TLS_CERT_FILE}}|${SMTPD_TLS_CERT_FILE}|g" \
    -e "s|{{SMTPD_TLS_KEY_FILE}}|${SMTPD_TLS_KEY_FILE}|g" \
    -e "s|{{SMTP_SASL_AUTH_ENABLE}}|${SMTP_SASL_AUTH_ENABLE}|g" \
    -e "s|{{SMTP_SASL_PASSWORD_MAPS}}|${SMTP_SASL_PASSWORD_MAPS}|g" \
    -e "s|{{SMTP_SASL_SECURITY_OPTIONS}}|${SMTP_SASL_SECURITY_OPTIONS}|g" \
    -e "s|{{SMTPD_SASL_AUTH_ENABLE}}|${SMTPD_SASL_AUTH_ENABLE}|g" \
    -e "s|{{SMTPD_SASL_TYPE}}|${SMTPD_SASL_TYPE}|g" \
    -e "s|{{SMTPD_SASL_PATH}}|${SMTPD_SASL_PATH}|g" \
    -e "s|{{SMTPD_RELAY_RESTRICTIONS}}|${SMTPD_RELAY_RESTRICTIONS}|g" \
    -e "s|{{SMTPD_RECIPIENT_RESTRICTIONS}}|${SMTPD_RECIPIENT_RESTRICTIONS}|g" \
    -e "s|{{SMTPD_CLIENT_RESTRICTIONS}}|${SMTPD_CLIENT_RESTRICTIONS}|g" \
    -e "s|{{VIRTUAL_ALIAS_DOMAINS}}|${VIRTUAL_ALIAS_DOMAINS}|g" \
    -e "s|{{VIRTUAL_ALIAS_MAPS}}|${VIRTUAL_ALIAS_MAPS}|g" \
    -e "s|{{VIRTUAL_MAILBOX_DOMAINS}}|${VIRTUAL_MAILBOX_DOMAINS}|g" \
    -e "s|{{VIRTUAL_MAILBOX_MAPS}}|${VIRTUAL_MAILBOX_MAPS}|g" \
    -e "s|{{MESSAGE_SIZE_LIMIT}}|${MESSAGE_SIZE_LIMIT}|g" \
    -e "s|{{MAILBOX_SIZE_LIMIT}}|${MAILBOX_SIZE_LIMIT}|g" \
    -e "s|{{DEFAULT_PROCESS_LIMIT}}|${DEFAULT_PROCESS_LIMIT}|g" \
    -e "s|{{SMTPD_CLIENT_CONNECTION_COUNT_LIMIT}}|${SMTPD_CLIENT_CONNECTION_COUNT_LIMIT}|g" \
    /etc/postfix/main.cf.tmpl > /etc/postfix/main.cf

# Убираем пустые строки которые остались от незаданных параметров
sed -i '/^[[:space:]]*$/d' /etc/postfix/main.cf

bashio::log.info "Configuration generated successfully."

# ── Aliases ──────────────────────────────────────────────────────────────────
if ! bashio::fs.file_exists '/config/postfix/aliases'; then
    bashio::log.info "No aliases file found, copying default..."
    mkdir -p /config/postfix
    cp /etc/postfix/aliases /config/postfix/aliases
fi

cp /config/postfix/aliases /etc/aliases
newaliases
bashio::log.info "Aliases loaded."

# ── Fix queue directory permissions ──────────────────────────────────────────
postfix set-permissions
bashio::log.info "Queue permissions set."
